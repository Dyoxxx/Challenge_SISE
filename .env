#  GestureDraw — Clés API
#  Copiez ce fichier à côté de main.py et remplissez vos clés
# ══════════════════════════════════════════════════════════

# ── MISTRAL (Enhance gestuel + analyse dessin) ────────────
#   Console : console.mistral.ai
MISTRAL_API_KEY=

# ── GÉNÉRATION D'IMAGE (choisir au moins 1) ───────────────

# ★ HuggingFace — GRATUIT, illimité
#   1. Créer compte sur huggingface.co
#   2. Settings → Access Tokens → New token (Read)
HUGGINGFACE_TOKEN=

# Anthropic Claude (analyse dessin)
ANTHROPIC_API_KEY=

# OpenAI GPT-4o + DALL-E 3
OPENAI_API_KEY=

# Google Gemini (gratuit sur aistudio.google.com)
GEMINI_API_KEY=

# ══════════════════════════════════════════════════════════
# Ordre de priorité génération (automatique) :
#   HuggingFace FLUX → Mistral FLUX1.1 → DALL-E 3
#   → Pollinations (gratuit sans clé) → Craiyon (dernier recours)
